# ==============================
# Root environment example
# ==============================
# Copy this file to .env and set real values in production.

# --- API ---
NODE_ENV=production
PORT=4000

# MongoDB Atlas connection string
# Example:
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_URI=

# JWT secrets (min 32 chars)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Frontend origin allowed for CORS + cookie configuration
# Example:
# CLIENT_ORIGIN=http://localhost:5173
CLIENT_ORIGIN=

# --- Web ---
# Vite: must start with VITE_
VITE_API_URL=http://localhost:4000/api/v1

